# Application
APP_NAME="Voxa AI Voice Agent"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://voxa:voxa_pass@localhost:5432/voxa_db
REDIS_URL=redis://localhost:6379/0

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# AI / LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Speech-to-Text
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
WHISPER_MODEL=base

# Text-to-Speech
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_FR=
ELEVENLABS_VOICE_ID_SW=
ELEVENLABS_VOICE_ID_RW=

# Vector Database (for RAG)
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=voxa-knowledge

# Chroma (local vector DB alternative)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Supported languages
SUPPORTED_LANGUAGES=en,fr,sw,rw

# Call settings
MAX_CALL_DURATION_SECONDS=1800
SILENCE_TIMEOUT_SECONDS=5
ESCALATION_THRESHOLD=3

# Booking
DEFAULT_APPOINTMENT_DURATION_MINUTES=30
BOOKING_ADVANCE_DAYS=30
